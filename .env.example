# ============================================================
# Drupal Config Navigator — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ============================================================

# ------------------------------------------------------------
# Groq API Key (required)
# ------------------------------------------------------------
# Get your free API key at: https://console.groq.com/keys
# The PoC uses Groq for fast streamed LLM inference.
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# Groq Model (optional — defaults shown below)
# ------------------------------------------------------------
# The model used for explanation and disambiguation.
# Current default: openai/gpt-oss-120b (OpenAI-compatible via Groq)
# Alternatives:  llama3-70b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=openai/gpt-oss-120b

# ------------------------------------------------------------
# Groq Inference Settings (optional)
# ------------------------------------------------------------
GROQ_MAX_TOKENS=1500
GROQ_TEMPERATURE=0.5
GROQ_REASONING_EFFORT=medium

# ------------------------------------------------------------
# Reflex App Settings (optional)
# ------------------------------------------------------------
# Port for the Reflex frontend (default: 3000)
# REFLEX_FRONTEND_PORT=3000

# Port for the Reflex backend API (default: 8000)
# REFLEX_BACKEND_PORT=8000

# Set to "true" to enable Reflex hot-reload in development
# REFLEX_HOT_RELOAD=true

# ------------------------------------------------------------
# Retrieval Settings (optional)
# ------------------------------------------------------------
# Minimum fuzzy-match score to include a result (0–100 scale)
# Lower = more results, higher = stricter matching
RETRIEVAL_MIN_SCORE=15

# Maximum number of candidates to retrieve and pass to Groq
RETRIEVAL_TOP_K=5

# ------------------------------------------------------------
# Notes
# ------------------------------------------------------------
# This PoC uses a local JSON metadata file for config pages.
# No Drupal instance, database, or vector store is required.
# The Groq API is the only external service dependency.
# ============================================================
